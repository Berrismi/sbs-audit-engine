{
  "name": "sbs-audit-engine",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Open source scoring engine and consultant CLI implementing the Security Benchmark for Salesforce (SBS) standard.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hellomavens/sbs-audit-engine.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24.15.0 <25",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.3",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "reuse:lint": "pipx run reuse lint",
    "sync:sbs": "pnpm --filter @hellomavens/security-review-for-salesforce-engine run sync:sbs",
    "validate:soql": "pnpm --filter @hellomavens/security-review-for-salesforce-scan-core run validate:soql",
    "validate:metadata": "pnpm --filter @hellomavens/security-review-for-salesforce-scan-core run validate:metadata",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,jsonc,yaml,yml,md}": [
      "prettier --write"
    ]
  }
}
