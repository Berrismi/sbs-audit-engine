{
  "name": "@hellomavens/security-review-for-salesforce-scan-core",
  "version": "0.0.0-alpha.48",
  "description": "Side-effecting evidence collector for the HelloMavens security review. Takes a Salesforce Connection + options, returns an EvidenceBundle (SOQL bundle, Health Check API, Code Analyzer subprocess output) the engine can score.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Berrismi/sbs-audit-engine.git",
    "directory": "packages/scan-core"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../sbs-engine/scripts/postbuild-add-extensions.mjs ./dist",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "validate:soql": "tsx scripts/validate-soql.ts",
    "validate:metadata": "tsx scripts/validate-metadata.ts"
  },
  "dependencies": {
    "@hellomavens/security-review-for-salesforce-engine": "workspace:*",
    "execa": "^9"
  },
  "devDependencies": {
    "@salesforce/core": "^8.29.0",
    "tsx": "^4.21.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
