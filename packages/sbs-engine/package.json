{
  "name": "@hellomavens/security-review-for-salesforce-engine",
  "version": "0.0.0-alpha.42",
  "description": "Open source scoring engine implementing the Security Benchmark for Salesforce (SBS) standard.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./controls": "./data/controls.json",
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "data",
    "rulesets",
    "README.md",
    "LICENSE",
    "ATTRIBUTION.md",
    "NOTICE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Berrismi/sbs-audit-engine.git",
    "directory": "packages/sbs-engine"
  },
  "homepage": "https://github.com/Berrismi/sbs-audit-engine#readme",
  "bugs": "https://github.com/Berrismi/sbs-audit-engine/issues",
  "keywords": [
    "salesforce",
    "security",
    "audit",
    "sbs",
    "security-benchmark-for-salesforce",
    "scoring-engine"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild-add-extensions.mjs",
    "clean": "rm -rf dist .tsbuildinfo",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sync:sbs": "tsx scripts/sync-sbs.ts",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test"
  },
  "devDependencies": {
    "smol-toml": "^1.4.2",
    "tsx": "^4.19.2",
    "yaml": "^2.8.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
