{
  "name": "@hellomavens/sbs-scan",
  "version": "0.0.0-dev",
  "description": "Consultant CLI for the HelloMavens SBS audit engine. Phase 5 of the Phase plan implements this; Phase 1 ships only a stub.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sbs-scan": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hellomavens/sbs-engine": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
